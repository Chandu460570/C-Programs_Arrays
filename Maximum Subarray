class Solution(object):
    def maxSubArray(self, nums):
        """
        :type nums: List[int]
        :rtype: int
        """
        n=len(nums)
        if n==0:
            return 0
        maxi = nums[0]
        curr = 0
        for i in nums:
            curr += i
            maxi = max(curr,maxi)

            if curr < 0:
                curr = 0
        return maxi
